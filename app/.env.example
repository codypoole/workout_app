# Firebase web app config — copy this file to ".env" and fill in your project's values.
# Find these under: Firebase Console > Project settings > General > Your apps > Web app (SDK setup & config).
#
# If you leave these blank, the app still runs and persists data locally (IndexedDB/localStorage)
# so you can develop offline. Fill them in to enable cloud sync + multi-device accounts.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional — enables Firebase Analytics (Google Analytics) when present.
VITE_FIREBASE_MEASUREMENT_ID=

